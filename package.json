{
  "name": "3dstu-farmflow",
  "version": "0.1.15",
  "description": "3DSTU FarmFlow 3D printing farm production operating system",
  "private": true,
  "author": "3DSTU <support@3dstu.com>",
  "homepage": "https://github.com/iain0901/3D-Printing-Farm-System#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iain0901/3D-Printing-Farm-System.git"
  },
  "bugs": {
    "email": "support@3dstu.com",
    "url": "https://github.com/iain0901/3D-Printing-Farm-System/issues"
  },
  "keywords": [
    "3dstu",
    "3d-printing",
    "print-farm",
    "farmflow",
    "scheduler",
    "slicer",
    "manufacturing",
    "saas"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "api": "node api/server.mjs",
    "worker": "node api/worker.mjs",
    "start": "node api/server.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "smoke": "npm run build",
    "smoke:prod": "node scripts/prod-smoke.mjs",
    "package:ubuntu": "node scripts/package-ubuntu.mjs package",
    "qc": "npm run build && npm run test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "fastify": "^5.8.5",
    "javascript-lp-solver": "^1.0.3",
    "jszip": "^3.10.1",
    "lowdb": "^7.0.1",
    "lucide-react": "^0.475.0",
    "mqtt": "^5.15.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "stripe": "^22.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
