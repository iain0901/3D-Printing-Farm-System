# Normalize line endings to LF for the Linux/Docker deploy target.
# Shell scripts MUST stay LF or the bash shebang breaks on the server.
* text=auto eol=lf
*.sh text eol=lf
*.mjs text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf

# Binary assets must never be line-ending converted.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.tgz binary
