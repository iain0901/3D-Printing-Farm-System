# Copy to .env before running docker compose in production-like environments.
LAYERPILOT_ADMIN_EMAIL=owner@example.com
LAYERPILOT_ADMIN_PASSWORD=change-this-password
LAYERPILOT_ADMIN_NAME=Production Owner
LAYERPILOT_WORKSPACE_NAME=3DSTU FarmFlow Production
# Public URL used by deployment smoke checks and external links.
LAYERPILOT_PUBLIC_URL=http://127.0.0.1:8797
# Bind Docker's published port to localhost by default for Nginx/HTTPS proxying.
# Set to 0.0.0.0 only when intentionally exposing :8797 directly.
LAYERPILOT_BIND_ADDRESS=127.0.0.1

# Set true for fresh production deployments so demo/default users are not kept.
LAYERPILOT_DISABLE_DEFAULT_USERS=true
LAYERPILOT_DISABLE_DEMO_LOGIN=true
LAYERPILOT_SESSION_TTL_HOURS=168
LAYERPILOT_SESSION_IDLE_TIMEOUT_HOURS=24
LAYERPILOT_METRICS_TOKEN=change-this-metrics-token
# Optional dedicated smoke account for scripts/ubuntu-deploy.sh ops-check.
# Leave blank to use the bootstrap admin credentials loaded from this file.
LAYERPILOT_OPS_EMAIL=
LAYERPILOT_OPS_PASSWORD=
LAYERPILOT_AUTO_BACKUP_ON_MIGRATE=true
LAYERPILOT_DB_ADAPTER=json
LAYERPILOT_BACKUP_RETENTION_DAYS=30
LAYERPILOT_PRE_RESTORE_BACKUP=true
LAYERPILOT_DEPLOY_LOCK_DIR=/tmp/layerpilot-deploy.lock
# For SQLite document storage, set:
# LAYERPILOT_DB_ADAPTER=sqlite
# and change LAYERPILOT_DB_PATH in docker-compose.yml to /data/layerpilot.sqlite

# Background worker for telemetry ticks and OctoPrint/Moonraker polling.
LAYERPILOT_WORKER_ID=layerpilot-worker
LAYERPILOT_WORKER_TELEMETRY=true
LAYERPILOT_WORKER_BRIDGE_POLLING=true
LAYERPILOT_WORKER_TELEMETRY_INTERVAL_MS=5000
LAYERPILOT_WORKER_BRIDGE_POLL_INTERVAL_MS=10000
LAYERPILOT_WORKER_TOKEN=change-this-worker-token

# Optional integrations.
LAYERPILOT_OBJECT_STORAGE_PROVIDER=local
LAYERPILOT_S3_BUCKET=
LAYERPILOT_S3_REGION=us-east-1
LAYERPILOT_S3_ENDPOINT=
LAYERPILOT_S3_PREFIX=layerpilot
LAYERPILOT_S3_FORCE_PATH_STYLE=false
LAYERPILOT_S3_ACCESS_KEY_ID=
LAYERPILOT_S3_SECRET_ACCESS_KEY=
LAYERPILOT_BILLING_PORTAL_URL=
LAYERPILOT_STRIPE_SECRET_KEY=
LAYERPILOT_STRIPE_WEBHOOK_SECRET=
LAYERPILOT_STRIPE_PRICE_STUDIO=
LAYERPILOT_STRIPE_PRICE_FARM=
LAYERPILOT_STRIPE_PRICE_ENTERPRISE=
LAYERPILOT_MQTT_URL=
LAYERPILOT_MQTT_TOPIC_PREFIX=layerpilot
LAYERPILOT_MQTT_USERNAME=
LAYERPILOT_MQTT_PASSWORD=
LAYERPILOT_MQTT_QOS=0
LAYERPILOT_MQTT_RETAIN=false
LAYERPILOT_SLICER_CMD=
LAYERPILOT_SLICER_ARGS=
